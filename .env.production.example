# Public DNS name pointed at the VPS. Caddy obtains and renews HTTPS certificates.
DEPLOY_HOST=thermoelastic.example.com
ACME_EMAIL=admin@example.com

APP_NAME=Thermoelastic Field Workspace API
APP_VERSION=0.1.0
ENVIRONMENT=production
API_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ORIGINS=https://thermoelastic.example.com
REMOTE_MODEL_TIMEOUT_SECONDS=90

# CPU inference profile. Raise these only after measuring real traffic.
MGN_DEVICE=cpu
MGN_DATASET_ID=sandstone_comsol_real
MGN_CONFIG_PATH=configs/inference.yaml
MGN_CHECKPOINT_PATH=outputs/checkpoints/best_model.pt
MGN_PREDICT_TIMEOUT_SECONDS=600
MGN_ROLLOUT_STEPS=1
MGN_ALLOW_FALLBACK=false

FNO_DEVICE=cpu
FNO_CHECKPOINT_PATH=/app/artifacts/checkpoints/baseline
FNO_CONFIG_PATH=/app/configs/inference.yaml
FNO_DATASET_PATH=/app/artifacts/datasets/sandstone_fno
FNO_ALLOW_FALLBACK=false

PINN_DEVICE=cpu
PINN_CHECKPOINT_PATH=/app/artifacts/checkpoints/baseline_cpu
PINN_REFERENCE_TEMPERATURE_K=293.15
PINN_TIME_SCALE=1.0

TRANSFORMER_DEVICE=cpu
TRANSFORMER_CHECKPOINT_PATH=/app/artifacts/checkpoints/smoke
TRANSFORMER_REFERENCE_TEMPERATURE_K=293.15
TRANSFORMER_TIME_SCALE=1.0
TRANSFORMER_ROLLOUT_STEPS=5

# Defaults target a 16 GB VPS. For an 8 GB demo VPS, see DEPLOYMENT.md.
GATEWAY_MEMORY_LIMIT=256m
FRONTEND_MEMORY_LIMIT=128m
BACKEND_MEMORY_LIMIT=768m
MGN_MEMORY_LIMIT=4g
FNO_MEMORY_LIMIT=2g
PINN_MEMORY_LIMIT=2g
TRANSFORMER_MEMORY_LIMIT=2g

GATEWAY_CPU_LIMIT=0.50
FRONTEND_CPU_LIMIT=0.50
BACKEND_CPU_LIMIT=1.00
MGN_CPU_LIMIT=2.00
FNO_CPU_LIMIT=1.50
PINN_CPU_LIMIT=2.00
TRANSFORMER_CPU_LIMIT=2.00
