APP_NAME=Thermoelastic Direction API
APP_VERSION=0.1.0
ENVIRONMENT=local
API_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
BACKEND_PORT=8000
FRONTEND_PORT=8080
MOCK_MESHGRAPHNET_PORT=9001
MOCK_FNO_PORT=9002
PINN_SERVICE_PORT=9003
REMOTE_MODEL_TIMEOUT_SECONDS=120

MODEL_MESHGRAPHNET_URL=http://meshgraphnet-service:9000
MODEL_FNO_URL=http://mock-fno:9000
MODEL_PINN_URL=http://pinn-service:9000

MODEL_MESHGRAPHNET_PREDICT_PATH=/predict
MODEL_FNO_PREDICT_PATH=/predict
MODEL_PINN_PREDICT_PATH=/predict

PINN_CHECKPOINT_PATH=/app/artifacts/checkpoints/baseline
PINN_DEVICE=cpu
PINN_LOG_LEVEL=INFO
PINN_REFERENCE_TEMPERATURE_K=293.15
PINN_TIME_SCALE=1.0

MESHGRAPHNET_SERVICE_PORT=9011
MGN_DATASET_ID=sandstone_comsol_real
MGN_CONFIG_PATH=configs/inference.yaml
MGN_CHECKPOINT_PATH=outputs/checkpoints_finetuned/best_model.pt
MGN_DEVICE=cuda
MGN_PREDICT_TIMEOUT_SECONDS=600
MGN_ROLLOUT_STEPS=1