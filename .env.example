APP_NAME=Thermoelastic Direction API
APP_VERSION=0.1.0
ENVIRONMENT=local
API_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
BACKEND_PORT=8000
FRONTEND_PORT=8080
MGN_SERVICE_PORT=9001
MOCK_FNO_PORT=9012
FNO_SERVICE_PORT=9002
MOCK_TRANSFORMER_PORT=9004
PINN_SERVICE_PORT=9003
TRANSFORMER_SERVICE_PORT=9004
REMOTE_MODEL_TIMEOUT_SECONDS=12
MODEL_MESHGRAPHNET_URL=http://mgn-service:9000
MODEL_FNO_URL=http://fno-service:9000
MODEL_PINN_URL=http://pinn-service:9000
MODEL_TRANSFORMER_URL=http://transformer-service:9000
MODEL_MESHGRAPHNET_PREDICT_PATH=/predict
MODEL_FNO_PREDICT_PATH=/predict
MODEL_PINN_PREDICT_PATH=/predict
MODEL_TRANSFORMER_PREDICT_PATH=/predict
FNO_CHECKPOINT_PATH=/app/artifacts/checkpoints/baseline
FNO_CONFIG_PATH=/app/configs/inference.yaml
FNO_DATASET_PATH=/app/artifacts/datasets/sandstone_fno
# Strict 2D retrain example:
# FNO_CHECKPOINT_PATH=/app/artifacts/checkpoints/baseline_2d
# FNO_DATASET_PATH=/app/artifacts/datasets_2d/limestone_fno_2d
FNO_DEVICE=cpu
FNO_LOG_LEVEL=INFO
FNO_ALLOW_FALLBACK=true
MGN_DATASET_ID=sandstone_comsol_real
MGN_CONFIG_PATH=configs/inference.yaml
MGN_CHECKPOINT_PATH=outputs/checkpoints/best_model.pt
# Strict 2D retrain example:
# MGN_DATASET_ID=limestone_rod_2d
# MGN_CONFIG_PATH=configs/inference.yaml
# MGN_CHECKPOINT_PATH=outputs/checkpoints_2d/best_model.pt
MGN_DEVICE=cuda
MGN_PREDICT_TIMEOUT_SECONDS=600
MGN_ROLLOUT_STEPS=5
MGN_ALLOW_FALLBACK=true
PINN_CHECKPOINT_PATH=/app/artifacts/checkpoints/baseline
# Strict 2D retrain example:
# PINN_CHECKPOINT_PATH=/app/artifacts/checkpoints/baseline_2d
PINN_DEVICE=cuda
PINN_LOG_LEVEL=INFO
PINN_REFERENCE_TEMPERATURE_K=293.15
PINN_TIME_SCALE=1.0
TRANSFORMER_CHECKPOINT_PATH=/app/artifacts/checkpoints/smoke
# Strict 2D retrain example:
# TRANSFORMER_CHECKPOINT_PATH=/app/artifacts/checkpoints/baseline_2d
TRANSFORMER_DEVICE=cpu
TRANSFORMER_LOG_LEVEL=INFO
TRANSFORMER_REFERENCE_TEMPERATURE_K=293.15
TRANSFORMER_TIME_SCALE=1.0
TRANSFORMER_ROLLOUT_STEPS=50
