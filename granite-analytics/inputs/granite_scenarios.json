      "fixed_overrides": {
        "source": {
          "type": "thermal_pulse",
          "z": 0.05,
          "direction": [0.82, 0.32, 0.47],
          "frequency_hz": 60.0
        },
        "domain": {
          "type": "rect_3d",
          "size": {
            "lx": 1.0,
            "ly": 1.0,
            "lz": 0.6
          },
          "resolution": {
