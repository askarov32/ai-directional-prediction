      "time_values_ms": [2.0, 5.0, 8.0, 11.0, 14.0, 17.0, 20.0, 23.0, 26.0],
      "probe_z_values": [0.02, 0.10, 0.18, 0.26, 0.34, 0.42, 0.50]
